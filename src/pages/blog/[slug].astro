---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout title={`${post.data.title} | modus6`} description={post.data.description}>
  <section class="section">
    <div class="container post">
      <div class="eyebrow">{post.data.category}</div>
      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.description}</p>
      <p class="small">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {post.data.author}</p>
      <div class="post-content"><Content /></div>
      <div class="cta-box" style="margin-top:48px">
        <h2>Ready to move from AI interest to prioritized action?</h2>
        <p>Start with a structured readiness conversation.</p>
        <div class="btn-row"><a class="btn btn-primary" href="/contact#calendar">Schedule Diagnostic</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
